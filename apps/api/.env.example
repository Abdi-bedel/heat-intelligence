# Supabase — Sprint 2A wiring
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# heat-app B2B API — see ../heat-app/docs/api/b2b_contracts.md
# Used by:
#   - cron (apps/api/src/cron/sources.ts) for check-ins + engagement events
#   - public live-counts proxy (apps/api/src/lib/live-counts.ts)
HEAT_APP_API_BASE_URL=https://api.heatapp.live
HEAT_APP_B2B_TOKEN=
HEAT_APP_B2B_CLIENT_NAME=heat-intelligence

# Legacy aliases (still honoured by the source factory). Prefer HEAT_APP_* above.
CONSUMER_API_BASE_URL=
CONSUMER_API_INTERNAL_TOKEN=

# Admin endpoint protection (cron manual trigger)
HEAT_ADMIN_TOKEN=

# Observability — Sprint 2A
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# Resend SMTP for Supabase Auth password-reset emails
RESEND_API_KEY=

PORT=8787
NODE_ENV=development
